# ── EOG Blog — environment ─────────────────────────────────────────────────
# Copy to .env and fill real values. NEVER commit the real .env.

# Admin login password (the editorial gate). Use a strong secret.
ADMIN_PASSWORD=change-me-before-deploying

# Extra salt for the session-cookie hash (any random string).
SESSION_SALT=change-me-random

# SQLite database file (created on first run; lives on the mounted volume).
DATABASE_URL=/app/data/blog.db

# ── Public identity (drives SEO/OG/sitemap/RSS + contact) ──────────────────
SITE_URL=https://ernestofgaia.xyz
SITE_NAME=Ernest of Gaia
# SITE_DESCRIPTION=...
CONTACT_SMS=503-664-0546
CONTACT_EMAIL=eog@ernestofgaia.xyz
# LINKEDIN_URL=https://www.linkedin.com/in/...

# ── Publishing agent intake (POST /blog/api/publishing-agent/draft) ────────
# The agent's ONLY capability: create one pending_review draft. Bearer token.
PUBLISHING_AGENT_API_KEY=change-me-to-a-strong-random-secret

# ── Scheduled release (POST/GET /blog/api/cron/publish-due, hit by VPS cron) ─
CRON_API_KEY=change-me-to-a-strong-random-secret

# ── Cadence (design plan 04 §3.5) — defaults shown ─────────────────────────
# PUBLISH_TIMEZONE=America/Los_Angeles
# PUBLISH_HOUR=9
# PUBLISH_CADENCE_DAYS=1

# ── Content guard ──────────────────────────────────────────────────────────
# EOG runs advisory (false). A client fork can set true to hard-block on findings.
# CONTENT_GUARD_HARD=false
